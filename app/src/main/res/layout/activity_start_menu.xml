<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <!-- ชื่อเกมกลางจอพร้อมเงาซ้อนสไตล์ Cyber Dynamic -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginBottom="60dp"
        android:shadowColor="#6366F1"
        android:shadowDx="6"
        android:shadowDy="6"
        android:shadowRadius="1"
        android:text="COIN WALK"
        android:textColor="#FFFFFF"
        android:textSize="44sp"
        android:textStyle="bold" />

    <!-- ปุ่มกดเริ่มเล่นเกม -->
    <TextView
        android:id="@+id/btnStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTitle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_green_border"
        android:paddingHorizontal="35dp"
        android:paddingVertical="14dp"
        android:text="TAP TO START"
        android:textColor="#10B981"
        android:textSize="18sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true" />

    <!-- คำไกด์ไลน์จางๆ ด้านล่างสุดของเมนูหลัก -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="45dp"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0.4">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-- SWIPE TO MOVE --"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.1" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JUMP | DUCK"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>
</RelativeLayout>